# --- Общие ---
ENV=production
LOG_LEVEL=INFO
HOST=vpn.example.com

# --- PostgreSQL ---
POSTGRES_USER=vpnmanager
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vpnmanager
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vpnmanager:change-me@db:5432/vpnmanager

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Безопасность ---
# Ключ шифрования Fernet: сгенерировать `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=change-me-fernet-key
SESSION_SECRET=change-me-session-secret
SESSION_TTL_HOURS=12

# --- Rate limit ---
LOGIN_RATE_LIMIT=5/5minutes
DOWNLOAD_RATE_LIMIT=20/minute

# --- Уведомления (опционально) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Прочее ---
DOWNLOAD_LINK_TTL_HOURS=2
OFFLINE_THRESHOLD_HOURS=48
PURGE_REVOKED_DAYS=30
