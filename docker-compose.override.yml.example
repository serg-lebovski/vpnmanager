# Скопируйте в docker-compose.override.yml для локальной разработки:
#   cp docker-compose.override.yml.example docker-compose.override.yml
services:
  backend:
    build:
      context: ./backend
      target: dev
    volumes:
      - ./backend/app:/app/app
      - ./backend/alembic:/app/alembic
      - ./data:/app/data
    environment:
      ENV: development
    command: >
      sh -c "alembic upgrade head &&
             uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
    ports:
      - "8000:8000"

  worker:
    volumes:
      - ./backend/app:/app/app
    environment:
      ENV: development

  db:
    ports:
      - "5432:5432"

  redis:
    ports:
      - "6379:6379"
